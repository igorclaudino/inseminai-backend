generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Species {
  cattle
  sheep
  goat
}

enum AnimalSex {
  male
  female
}

enum MemberRole {
  admin
  operator
}

enum InvitationStatus {
  pending
  accepted
  expired
}

enum AiProfileId {
  essential
  brief
  standard
  expert
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id                   String    @id @default(uuid())
  name                 String
  email                String    @unique
  password             String
  mustChangePassword   Boolean   @default(false)
  passwordResetToken   String?   @unique
  passwordResetExpires DateTime?
  createdAt            DateTime  @default(now())

  farms           Farm[]
  farmMemberships FarmMember[]     @relation("UserMemberships")
  sentInvitations FarmInvitation[] @relation("SentInvitations")
}

model Farm {
  id                   String      @id @default(uuid())
  name                 String
  city                 String?
  state                String?
  averagePregnancyRate Int         @default(0)
  aiProfile            AiProfileId @default(standard)
  createdAt            DateTime    @default(now())
  deletedAt            DateTime?

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id])

  animals     Animal[]
  members     FarmMember[]
  invitations FarmInvitation[]
}

model Animal {
  id                         String    @id @default(uuid())
  identifier                 String
  rfid                       String?
  species                    Species
  name                       String
  breed                      String
  lineage                    String?
  sex                        AnimalSex
  birthDate                  DateTime?
  // Ready | Pregnant | In Reproduction | Culled | Inactive
  reproductiveStatus         String    @default("Ready")
  producer                   String?
  photoUrl                   String?
  active                     Boolean   @default(true)
  deletedAt                  DateTime?
  deletionReason             String?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  // Reproductive history (as female)
  pregnancyHistory           Int       @default(0)
  abortionCount              Int       @default(0)
  birthCount                 Int       @default(0)
  heatDetectionCount         Int       @default(0)
  averageBirthInterval       Int       @default(0)
  lastBirthDate              DateTime?
  bodyConditionScore         Int       @default(3)
  reproductiveDiseaseHistory Boolean   @default(false)

  // Growth metrics
  birthWeight          Float?
  preWeaningWeightGain Float?
  weaningWeight        Float?

  // Sire performance tracking (when used as male in inseminations)
  fertilityScore       Int @default(0)
  totalInseminations   Int @default(0)
  pregnanciesAsBreeder Int @default(0)

  farmId String
  farm   Farm   @relation(fields: [farmId], references: [id])

  // Genealogy
  sireId        String?
  sire          Animal?  @relation("OffspringSire", fields: [sireId], references: [id])
  sireOffspring Animal[] @relation("OffspringSire")

  damId        String?
  dam          Animal?  @relation("OffspringDam", fields: [damId], references: [id])
  damOffspring Animal[] @relation("OffspringDam")

  weighings             Weighing[]
  reproductiveEvents    ReproductiveEvent[]
  predictions           Prediction[]
  inseminationsAsSire   ReproductiveEvent[] @relation("InseminationSire")
  predictionsAsSire     Prediction[]        @relation("PredictionSire")

  @@unique([farmId, identifier])
  @@index([farmId, active])
  @@index([farmId, species])
}

model Weighing {
  id           String   @id @default(uuid())
  weightKg     Float
  weighingDate DateTime
  notes        String?
  createdAt    DateTime @default(now())

  animalId String
  animal   Animal @relation(fields: [animalId], references: [id])

  @@index([animalId, weighingDate])
}

model ReproductiveEvent {
  id String @id @default(uuid())

  // artificial_insemination | natural_mating | controlled_mating | heat | birth | abortion | pregnancy
  eventType String

  inseminator          String?
  semenUsed            String?
  lot                  String?
  reproductiveProtocol String?

  // pending | positive | negative | conception_failure
  pregnancyDiagnosis String   @default("pending")
  result             String?

  eventDate        DateTime
  confirmationDate DateTime?
  notes            String?
  createdAt        DateTime @default(now())

  animalId String
  animal   Animal @relation(fields: [animalId], references: [id])

  sireId     String?
  sireAnimal Animal?  @relation("InseminationSire", fields: [sireId], references: [id])

  prediction Prediction?

  @@index([animalId, eventDate])
}

model Prediction {
  id                   String   @id @default(uuid())
  pregnancyProbability Int
  fertilityScore       Int
  riskLevel            String   // low | moderate | high
  geneticCompatibility Int?
  positiveFactors      String[]
  alerts               String[]
  recommendations      String[]
  aiInsight            String?
  protocol             String?
  ambientTemperature   Float?
  season               String?
  createdAt            DateTime @default(now())

  aiProfile    AiProfileId @default(standard)
  inputTokens  Int         @default(0)
  outputTokens Int         @default(0)
  // pregnancy | best_breeder | best_dam
  analysisType String      @default("pregnancy")

  animalId String?
  animal   Animal? @relation(fields: [animalId], references: [id])

  sireId     String?
  sireAnimal Animal?  @relation("PredictionSire", fields: [sireId], references: [id])

  reproductiveEventId String?            @unique
  reproductiveEvent   ReproductiveEvent? @relation(fields: [reproductiveEventId], references: [id])

  @@index([animalId, createdAt])
}

model FarmMember {
  id       String     @id @default(uuid())
  role     MemberRole
  joinedAt DateTime   @default(now())

  farmId String
  farm   Farm   @relation(fields: [farmId], references: [id])

  userId String
  user   User   @relation("UserMemberships", fields: [userId], references: [id])

  @@unique([farmId, userId])
  @@map("farm_members")
}

model FarmInvitation {
  id        String           @id @default(uuid())
  email     String
  role      MemberRole
  token     String           @unique @default(uuid())
  status    InvitationStatus @default(pending)
  expiresAt DateTime
  createdAt DateTime         @default(now())

  farmId      String
  farm        Farm   @relation(fields: [farmId], references: [id])

  invitedById String
  invitedBy   User   @relation("SentInvitations", fields: [invitedById], references: [id])

  @@index([farmId, status])
  @@map("farm_invitations")
}
