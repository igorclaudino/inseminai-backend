# ─── Database (Neon) ──────────────────────────────────────────────────────────
# Pooled connection — used at runtime by the application
DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require"

# Direct (non-pooled) connection — required by Prisma Migrate on Neon
DIRECT_URL="postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Must be at least 32 characters
JWT_SECRET="replace-with-a-very-long-random-string-min-32-chars"
JWT_EXPIRES_IN="7d"

# ─── Backoffice ───────────────────────────────────────────────────────────────
# Secret used to protect POST /backoffice/create-admin (min 16 chars)
BACKOFFICE_SECRET="replace-with-backoffice-secret-min-16-chars"

# ─── AI ───────────────────────────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."

# ─── Server ───────────────────────────────────────────────────────────────────
# Render injects PORT automatically; set 3001 for local dev
PORT=3001

# Origin allowed by CORS — set to your frontend URL in production
FRONTEND_URL="http://localhost:3000"

# ─── Mail (optional) ─────────────────────────────────────────────────────────
MAIL_HOST="smtp.example.com"
MAIL_PORT=587
MAIL_USER="no-reply@example.com"
MAIL_PASS="your-smtp-password"
MAIL_FROM="InsemiAI <no-reply@example.com>"
